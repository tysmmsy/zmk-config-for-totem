if SHIELD_TOTEM_LEFT || SHIELD_TOTEM_RIGHT || SHIELD_TOTEM_DONGLE

config ZMK_SPLIT
    default y

config ZMK_BLE
    default y

endif # SHIELD_TOTEM_LEFT || SHIELD_TOTEM_RIGHT || SHIELD_TOTEM_DONGLE

if SHIELD_TOTEM_DONGLE || SHIELD_TOTEM_LEFT

config ZMK_SPLIT_ROLE_CENTRAL
    default y

if ZMK_SPLIT_ROLE_CENTRAL

config ZMK_KEYBOARD_NAME
    default "Totem"

endif # ZMK_SPLIT_ROLE_CENTRAL

endif # SHIELD_TOTEM_DONGLE || SHIELD_TOTEM_LEFT
